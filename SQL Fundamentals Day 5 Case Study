-- 10.	In the first week after a customer joins the program (including their join date) they earn 2x points on all items, not just sushi -
-- how many points do customer A and B have at the end of January?

-- me 
SELECT 
	*,
    price * 20 AS points
FROM
	sales
JOIN
	menu USING(product_id)
JOIN
	members USING(customer_id)
WHERE order_date >= join_date AND order_date < join_date + 7;

-- Instructor

WITH dates AS
(
SELECT
	*,
    DATE_ADD(join_date, INTERVAL 6 DAY) as first_week,
    LAST_DAY('2021-01-01') AS last_date
FROM
	members
)
SELECT 
	customer_id,
	SUM(
		CASE
			WHEN product_name = 'sushi' THEN price * 20
			WHEN order_date BETWEEN join_date AND last_date THEN price * 20
			ELSE price * 10
		END) AS points
FROM 
	dates 
    JOIN sales USING(customer_id) 
	JOIN menu USING(product_id)
WHERE order_date < last_date
GROUP BY 
	customer_id;

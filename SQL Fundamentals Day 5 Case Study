-- 5.	Which item was the most popular for each customer?
-- me
WITH rank_table AS (
SELECT
	customer_id,
    product_name,
	COUNT(product_name) AS total_count,
    ROW_NUMBER() OVER (PARTITION BY customer_id ORDER BY COUNT(product_name) DESC) as rnk
FROM
	sales s
JOIN
	menu m
	ON s.product_id = m.product_id
GROUP BY
	customer_id,
    product_name
ORDER BY customer_id, total_count DESC)
SELECT
	*
FROM 
	rank_table
WHERE rnk = 1;


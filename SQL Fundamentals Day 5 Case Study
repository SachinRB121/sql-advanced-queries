-- 9.	If each $1 spent equates to 10 points and sushi has a 2x points multiplier - how many points would each customer have?

WITH new_table AS 
(SELECT 
	*,
    CASE
		WHEN product_name = 'sushi' THEN price*20
        ELSE price * 10
	END AS points
FROM
	sales
JOIN
	menu USING(product_id)
)
SELECT 
	customer_id,
    SUM(points)
FROM
	new_table
GROUP BY 
	customer_id;


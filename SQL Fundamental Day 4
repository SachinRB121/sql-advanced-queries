-- 1.	What is the total amount each customer spent at the restaurant?

SELECT 
	customer_id,
    SUM(price) AS total_amount
FROM
	sales
INNER JOIN
	menu
    ON sales.product_id = menu.product_id
GROUP BY
	customer_id;
-- ======================================================================
-- 2.	How many days has each customer visited the restaurant?
SELECT
	customer_id,
    COUNT(DISTINCT(order_date)) visit_count
FROM
	sales
GROUP BY customer_id;
-- ======================================================================
-- 3.	What was the first item from the menu purchased by each customer?
-- Using Subquery
SELECT
	*
FROM
	(SELECT
		sales.customer_id,
		sales.order_date,
		menu.product_name,
		ROW_NUMBER()OVER(PARTITION BY sales.customer_id ORDER BY sales.order_date) as first_item
	FROM 
		sales
	JOIN 
		menu
		ON sales.product_id = menu.product_id) as a
WHERE
	first_item = 1;

-- Usin CTE
WITH item as (
	SELECT
		sales.customer_id,
		sales.order_date,
		menu.product_name,
		ROW_NUMBER()OVER(PARTITION BY sales.customer_id ORDER BY sales.order_date) as first_item
	FROM 
		sales
	JOIN 
		menu
		ON sales.product_id = menu.product_id
	) 
SELECT 
	customer_id, 
	product_name
FROM 
	item 
WHERE 
	first_item = 1;

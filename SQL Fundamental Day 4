-- 6.	Which item was purchased first by the customer after they became a member?

WITH first_order AS
(SELECT
	s.customer_id,
    m.join_date,
    s.order_date,
    mn.product_name,
    ROW_NUMBER() OVER(PARTITION BY s.customer_id ORDER BY s.order_date) AS fdate
FROM
	sales s
JOIN 
	members m
    ON s.customer_id = m.customer_id
JOIN
	menu mn
    ON s.product_id = mn.product_id
WHERE s.order_date > m.join_date)
SELECT 
	*
FROM 
	first_order
WHERE fdate = 1;
    
-- =========================================================================
-- 7.	Which item was purchased just before the customer became a member?
WITH before_order AS 
(
SELECT
	s.customer_id,
    m.join_date,
    s.order_date,
    mn.product_name,
    ROW_NUMBER() OVER(PARTITION BY s.customer_id ORDER BY s.order_date) AS rnk
FROM 
	sales s
JOIN 
	members m
    ON s.customer_id = m.customer_id
JOIN 
	menu mn
    ON s.product_id = mn.product_id
WHERE 
	s.order_date < m.join_date)
SELECT 
	*
FROM before_order
WHERE rnk = 1;


-- CREATING A TABLE IN THE DATABASE librarydb
-- Library --> Database
-- Library Section --> Tables
-- Bookshelves --> Columns in the table
-- Books --> Records in a table (rows of data)


-- Before creating the table makesure the database is selected 
USE librarydb;

CREATE TABLE bookstemp
(
	BookID INT PRIMARY KEY,
	Title VARCHAR(255),
	Autohor VARCHAR(255),
	Genre VARCHAR(100),
	PublishedYear INT
);
-- create table command is used to define table with specific columns and data types.
    
-- show tables 
show tables;
 
-- describing a table
describe books;
-- displays all the columns, their datatypes, and constraints

